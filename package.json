{
  "name": "flowpilot",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Browser Automation & Website Testing Platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@flowpilot/desktop",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @flowpilot/data-access db:generate",
    "db:migrate": "pnpm --filter @flowpilot/data-access db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  }
}
